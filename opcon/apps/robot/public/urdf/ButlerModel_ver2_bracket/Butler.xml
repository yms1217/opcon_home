<mujoco model="butler_model">

    <compiler angle="radian" meshdir="assets"/>

    <option integrator="implicitfast" cone="elliptic" impratio="10"/>

    <default>
        <default class="piper">
            <joint frictionloss="0.3" armature="0.005"/>
            <position inheritrange="1" forcerange="-100 100"/>
            <default class="finger">
                <joint frictionloss="0" type="slide"/>
                <position forcerange="-10 10"/>
            </default>
            <default class="visual">
                <geom group="2" type="mesh" contype="0" conaffinity="0" density="0"/>
            </default>
            <default class="collision">
                <geom group="3" type="capsule"/>
            </default>
        </default>


        <default class="d435i">
            <material specular="0" shininess="0.25"/>
            <default class="d435i_visual">
                <geom group="2" type="mesh" contype="0" conaffinity="0" mass="0"/>
            </default>
            <default class="d435i_collision">
                <geom group="3" type="mesh" mass="0"/>
            </default>
        </default>

    </default>

